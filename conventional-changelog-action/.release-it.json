{
  "git": {
    "commit": false
  },
  "github": {
    "release": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "feat",
            "section": ":rocket: Features"
          },
          {
            "type": "fix",
            "section": ":bug: Bug fixes"
          },
          {
            "type": "ci",
            "section": ":robot: CI/CD"
          },
          {
            "type": "docs",
            "section": ":page_facing_up: Docs"
          },
          {
            "type": "test",
            "section": ":test_tube: Tests"
          },
          {
            "type": "build",
            "section": ":package: Build"
          },
          {
            "type": "style",
            "section": ":broom: Style"
          },
          {
            "type": "chore",
            "hidden": true
          },
        ]
      }
    }
  }
}
